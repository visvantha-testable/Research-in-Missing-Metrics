    "source": "export function loopNesting(items) {\n  let total = 0;\n  for (const item of items) {\n    if (item > 0) {\n      for (const nested of items) {\n        if (nested > 10) {\n          for (const deep of items) {\n            if (deep > 20) {\n              total += deep;\n            }\n          }\n        }\n      }\n    }\n  }\n  return total;\n}\n",
