e","statusReason":"expected 99 to be 10 // Object.is equality","status":"Killed","static":false,"testsCompleted":1,"killedBy":["4"],"coveredBy":["4"],"location":{"end":{"column":34,"line":49},"start":{"column":7,"line":49}}},{"id":"61","mutatorName":"BlockStatement","replacement":"{}","statusReason":"expected 99 to be 10 // Object.is equality","status":"Killed","static":false,"testsCompleted":1,"killedBy":["4"],"coveredBy":["4"],"location":{"end":{"column":4,"line":51},"start":{"column":36,"line":49}}}],"source":"export type Grade = \"fail\" | \"pass\" | \"excellent\";\r\n\r\n/** Boundary-sensitive grading — kills boundary mutants when fully tested. */\r\nexport function gradeScore(score: number): Grade {\r\n  if (score < 50) {\r\n    return \"fail\";\r\n  }\r\n  if (score < 75) {\r\n    return \"pass\";\r\n  }\r\n  return \"excellent\";\r\n}\r\n\r\n/** Strict comparisons — kills EqualityOperator / RelationalOperator mutants. */\r\nexport function isStrictlyBelow(value: number, threshold: number): boolean {\r\n  return value < threshold;\r\n}\r\n\r\nexport function isStrictlyAbove(value: number, threshold: number): boolean {\r\n  return value > threshold;\r\n}\r\n\r\nexport function inRange(value: number, min: number, max: number): boolean {\r\n  return value >= min && value <= max;\r\n}\r\n\r\nexport function classifySign(n: number): \"negative\" | \"zero\" | \"positive\" {\r\n  if (n < 0) {\r\n    return \"negative\";\r\n  }\r\n  if (n === 0) {\r\n    return \"zero\";\r\n  }\r\n  return \"positive\";\r\n}\r\n\r\n/** On equal inputs prefer the first operand — kills >= vs > mutant. */\r\nexport function pickLargerWithTieBreaker(a: number, b: number): \"a\" | \"b\" {\r\n  if (a >= b) {\r\n    return \"a\";\r\n  }\r\n  return \"b\";\r\n}\r\n\r\nexport function clamp(value: number, min: number, max: number): number {\r\n  if (isStrictlyBelow(value, min)) {\r\n    return min;\r\n  }\r\n  if (isStrictlyAbove(value, max)) {\r\n    return max;\r\n  }\r\n  return value;\r\n}\r\n"}},"schemaVersion":"1.0","thresholds":{"high":100,"break":100,"low":100},"testFiles":{"sample_subject/tests/mutants.test.ts":{"tests":[{"id":"0","name":"mutants — mutation-testing subject gradeScore kills boundary mutants at 50 and 75"},{"id":"1","name":"mutants — mutation-testing subject isStrictlyBelow kills <= boundary mutants"},{"id":"2","name":"mutants — mutation-testing subject isStrictlyAbove kills >= boundary mutants"},{"id":"3","name":"mutants — mutation-testing subject inRange kills comparator mutants"},{"id":"4","name":"mutants — mutation-testing subject clamp kills min/max branch mutants via strict helpers"},{"id":"5","name":"mutants — mutation-testing subject classifySign kills sign comparison mutants"},{"id":"6","name":"mutants — mutation-testing subject pickLargerWithTieBreaker kills >= vs > mutant on ties"}],"source":"import { describe, expect, it } from \"vitest\";\r\nimport {\r\n  classifySign,\r\n  clamp,\r\n  gradeScore,\r\n  inRange,\r\n  isStrictlyAbove,\r\n  isStrictlyBelow,\r\n  pickLargerWithTieBreaker,\r\n} from \"../src/mutants.js\";\r\n\r\ndescribe(\"mutants — mutation-testing subject\", () => {\r\n  it(\"gradeScore kills boundary mutants at 50 and 75\", () => {\r\n    expect(gradeScore(0)).toBe(\"fail\");\r\n    expect(gradeScore(49)).toBe(\"fail\");\r\n    expect(gradeScore(50)).toBe(\"pass\");\r\n    expect(gradeScore(74)).toBe(\"pass\");\r\n    expect(gradeScore(75)).toBe(\"excellent\");\r\n    expect(gradeScore(100)).toBe(\"excellent\");\r\n  });\r\n\r\n  it(\"isStrictlyBelow kills <= boundary mutants\", () => {\r\n    expect(isStrictlyBelow(4, 5)).toBe(true);\r\n    expect(isStrictlyBelow(5, 5)).toBe(false);\r\n    expect(isStrictlyBelow(6, 5)).toBe(false);\r\n  });\r\n\r\n  it(\"isStrictlyAbove kills >= boundary mutants\", () => {\r\n    expect(isStrictlyAbove(6, 5)).toBe(true);\r\n    expect(isStrictlyAbove(5, 5)).toBe(false);\r\n    expect(isStrictlyAbove(4, 5)).toBe(false);\r\n  });\r\n\r\n  it(\"inRange kills comparator mutants\", () => {\r\n    expect(inRange(5, 1, 10)).toBe(true);\r\n    expect(inRange(1, 1, 10)).toBe(true);\r\n    expect(inRange(10, 1, 10)).toBe(true);\r\n    expect(inRange(0, 1, 10)).toBe(false);\r\n    expect(inRange(11, 1, 10)).toBe(false);\r\n  });\r\n\r\n  it(\"clamp kills min/max branch mutants via strict helpers\", () => {\r\n    expect(clamp(5, 1, 10)).toBe(5);\r\n    expect(clamp(0, 1, 10)).toBe(1);\r\n    expect(clamp(99, 1, 10)).toBe(10);\r\n    expect(clamp(1, 1, 10)).toBe(1);\r\n    expect(clamp(10, 1, 10)).toBe(10);\r\n  });\r\n\r\n  it(\"classifySign kills sign comparison mutants\", () => {\r\n    expect(classifySign(-1)).toBe(\"negative\");\r\n    expect(classifySign(0)).toBe(\"zero\");\r\n    expect(classifySign(1)).toBe(\"positive\");\r\n  });\r\n\r\n  it(\"pickLargerWithTieBreaker kills >= vs > mutant on ties\", () => {\r\n    expect(pickLargerWithTieBreaker(2, 5)).toBe(\"b\");\r\n    expect(pickLargerWithTieBreaker(7, 3)).toBe(\"a\");\r\n    expect(pickLargerWithTieBreaker(4, 4)).toBe(\"a\");\r\n  });\r\n});\r\n"}},"projectRoot":"D:\\Research in Missing Metrics\\typescript\\Stryker Mutation Testing\\workspace\\typescript-tool-testing-stryker-mutator-core","config":{"$schema":"./node_modules/@stryker-mutator/core/schema/stryker-schema.json","packageManager":"npm","plugins":["@stryker-mutator/vitest-runner","./dist/stryker/taxonomyEnrichedJsonReporterPlugin.js"],"testRunner":"vitest","reporters":["taxonomy-enriched-json","clear-text"],"jsonReporter":{"fileName":"artifacts/training/mutation/mutation-report.json"},"coverageAnalysis":"perTest","mutate":["sample_subject/src/**/*.ts","!sample_subject/src/index.ts"],"vitest":{"configFile":"vitest.config.ts","related":true},"thresholds":{"high":100,"break":100,"low":100},"timeoutMS":60000,"concurrency":2,"allowConsoleColors":true,"checkers":[],"checkerNodeArgs":[],"commandRunner":{"command":"npm test"},"clearTextReporter":{"allowColor":true,"allowEmojis":false,"logTests":true,"maxTestsToLog":3,"reportT